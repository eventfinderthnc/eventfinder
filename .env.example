# Drizzle
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL="postgresql://postgres:password@localhost:5432/eventfinder"

# Better Auth
BETTER_AUTH_SECRET=dummy
# Public URL of this deployment (local dev, Vercel preview, or production). Used for OAuth, links, TRPC, calendar claim redirects, and (via next.config) the browser auth/TRPC base URL.
BETTER_AUTH_URL=http://localhost:3000
# Optional override for client bundles; defaults to BETTER_AUTH_URL.
# NEXT_PUBLIC_BETTER_AUTH_URL=https://your-app.vercel.app

RESEND_API_KEY=
# Verified sender in Resend (e.g. onboarding@resend.dev for dev)
EMAIL_FROM=
CALENDAR_CLAIM_SECRET=

# Google Client
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

R2_ACCESS_KEY_ID=dummy
R2_SECRET_ACCESS_KEY=dummy
R2_ENDPOINT=dummy
R2_BUCKET=dummy
# Public URL for bucket (enable Public access in R2; use r2.dev URL or custom domain subdomain)
R2_PUBLIC_BASE_URL=https://pub-dummy.r2.dev